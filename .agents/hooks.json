{
  "pre-agent-wflow": {
      "enabled": false,
      "PreInvocation": [
        {
          "type": "command",
          "command": "./scripts/reminder.sh"
        }
      ]
    },
  "pre-tool-wflow": {
      "enabled": false,
      "PreToolUse": [
        {
          "matcher": "run_command",
          "hooks": [
            {
	      "type": "command"
              "command": "./scripts/safety-check.sh",
	      "timeout": 10
            }
          ]
        }
      ]
    },
  "post-tool-wflow": {
      "enabled": false,
      "PostToolUse": [    
        {
          "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
          "hooks": [
            {
              "type": "command",
              "command": "./scripts/validate.sh",
              "timeout": 60,
            }
          ]
        }
      ]
    },
  "post-agent-wflow": {
      "enabled": false,
      "PostInvocation": [
        {
          "type": "command",
          "command": "./scripts/reminder.sh"
        }
      ]
    }
}

